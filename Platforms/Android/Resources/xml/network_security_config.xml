<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">gigachat.devices.sberbank.ru</domain>
        <domain includeSubdomains="true">ngw.devices.sberbank.ru</domain>
        <domain includeSubdomains="true">api.gigachat.ru</domain>
    </domain-config>
    
    <!-- Для отладки разрешаем все сертификаты -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>