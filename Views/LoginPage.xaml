<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Giga.ViewModels"
             x:Class="Giga.Views.LoginPage"
             Title="Авторизация">

    <VerticalStackLayout Padding="30,20" 
                         Spacing="20" 
                         VerticalOptions="Center"
                         HorizontalOptions="Center">

        <Label Text="🔑 GigaChat"
               FontSize="32"
               FontAttributes="Bold"
               TextColor="#3465A4"
               HorizontalOptions="Center" />

        <Label Text="Введите ваш ключ API для доступа к GigaChat"
               FontSize="16"
               TextColor="Gray"
               HorizontalOptions="Center" />

        <BoxView HeightRequest="1" 
                 Color="LightGray" 
                 Margin="0,10,0,20" />

        <Entry Placeholder="Введите ключ API..."
               Text="{Binding ApiKey, Mode=TwoWay}"
               ReturnType="Done"
               ReturnCommand="{Binding LoginCommand}"
               IsPassword="False"
               FontSize="16"
               HeightRequest="50"
               BackgroundColor="#F0F0F0"
               TextColor="Black"
               Margin="0,0,0,10" />

        <Button Text="Войти"
                Command="{Binding LoginCommand}"
                IsEnabled="{Binding IsNotLoggingIn}"
                BackgroundColor="#3465A4"
                TextColor="White"
                FontSize="18"
                FontAttributes="Bold"
                CornerRadius="10"
                HeightRequest="50"
                WidthRequest="200"
                HorizontalOptions="Center" />

        <ActivityIndicator IsVisible="{Binding IsLoggingIn}"
                           IsRunning="{Binding IsLoggingIn}"
                           HorizontalOptions="Center"
                           Margin="0,10,0,0" />

        <Label Text="{Binding StatusMessage}"
               FontSize="14"
               TextColor="Red"
               HorizontalOptions="Center"
               IsVisible="{Binding HasStatusMessage}" />

    </VerticalStackLayout>
</ContentPage>